# Groq Cloud API key for AI-generated news, press questions, social posts, and fan comments.
# Get your free key at https://console.groq.com
VITE_GROQ_API_KEY=your_groq_api_key_here

# Football-data.org API key (only needed to refresh baked data).
# Edit the key in scripts/fetchData.mjs and run: node scripts/fetchData.mjs
FOOTBALL_DATA_API_KEY=your_api_key_here
