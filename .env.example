# The football-data.org key is now hardcoded in src/services/footballData.ts,
# so no environment variable is required. This file is kept only for reference.
# NOTE: because this is a browser app, the hardcoded key is visible in the
# built bundle (devtools -> Sources). football-data.org allows CORS, so direct
# browser calls work.
FOOTBALL_DATA_API_KEY=your_api_key_here
